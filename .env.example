# Copy this file to .env and fill in values before running
MONGO_URI=mongodb+srv://tanish105:<PASSWORD>@cluster0.nwznot3.mongodb.net/cabbie?retryWrites=true&w=majority

# Set to true to launch emulators with a GUI window (debug mode).
# When false or unset, emulators run headless (-no-window).
DEBUG=false

# Deep link strategy for Uber. Options:
#   universal  — https://m.uber.com/ul/ link (shows upfront fares, recommended)
#   custom     — uber:// scheme with lat/lng coords (may show "fare after confirmation")
#   none       — disable deep links, always use UI navigation
UBER_DEEPLINK_STYLE=universal
