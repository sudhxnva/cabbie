# Copy this file to .env and fill in values before running
# ========================================================
# REQUIRED
# ========================================================
ANTHROPIC_API_KEY=sk-ant-...
# API keys for authentication (comma-separated)
# Example: API_KEYS=key1,key2,key3
API_KEYS=

# MongoDB connection string
# Local: mongodb://mongodb:27017/cabbie
# Atlas: mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/cabbie
MONGODB_URI=mongodb://mongodb:27017/cabbie

# ========================================================
# SERVER CONFIGURATION
# ========================================================
PORT=3000
NODE_ENV=production

# ========================================================
# EMULATOR CONFIGURATION
# ========================================================
# Set to "local" for local Android SDK mount, "remote" for external emulator
EMULATOR_MODE=local

# For local mode: path to Android SDK on HOST (mounted into container)
ANDROID_SDK_HOST_PATH=~/Android/Sdk

# For remote mode: emulator serial(s) to connect to (comma-separated)
EMULATOR_SERIALS=emulator-5554,emulator-5556

# ========================================================
# MCP SERVER CONFIGURATION
# ========================================================
# Command and args for the ADB MCP server
MCP_SERVER_COMMAND=npx
MCP_SERVER_ARGS=-y adb-mcp

# Optional: Android MCP Server directory (if using uv-based server)
# ANDROID_MCP_DIRECTORY=/path/to/android-mcp-server

# ========================================================
# DEBUGGING
# ========================================================
# Set to true to launch emulators with a GUI window (debug mode).
# When false or unset, emulators run headless (-no-window).
DEBUG=false

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
